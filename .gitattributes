# Enforce consistent line endings across platforms.
# Text files are normalized to LF in the repository and checked out as LF
# everywhere (overrides each developer's core.autocrlf setting).
* text=auto eol=lf

# Windows-only scripts must keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Known binary types: never normalize.
*.jar   binary
*.war   binary
*.class binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
